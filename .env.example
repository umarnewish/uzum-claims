# Shared with vendex — must match vendex SECRET_KEY for JWT to validate
SECRET_KEY=change-me-must-match-vendex

# Postgres — same instance as vendex, schema=claims
DATABASE_URL=postgresql+asyncpg://vendex:vendex@localhost:5432/vendex
DB_SCHEMA=claims

# Vendex internal URL (for cross-service calls: /api/me, /api/integrations/shops)
VENDEX_INTERNAL_URL=http://localhost:8000

# Where generated docx are stored
GENERATED_DIR=/var/uzum-claims/generated
